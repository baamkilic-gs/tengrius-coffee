generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==== Kullanıcı & Organizasyon ====

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  phone         String?
  password_hash String
  full_name     String
  role          SystemRole @default(MEMBER) // MEMBER | ADMIN
  mfa_enabled   Boolean    @default(false)
  mfa_secret    String?
  created_at    DateTime   @default(now())

  organizations OrganizationMember[]
}

model Organization {
  id                    String         @id @default(uuid())
  name                  String
  type                  OrgType // SELLER | ROASTER
  country               String?
  membership_tier       MembershipTier @default(STANDARD) // STANDARD | PREMIUM
  membership_expires_at DateTime?
  trust_score           Int            @default(0)
  verified              Boolean        @default(false) // "Yetkili Satıcı" rozeti — yalnızca admin verir
  created_at            DateTime       @default(now())

  // ==== Satıcı kayıt alanları ====
  tax_number          String? // Vergi numarası
  tax_office          String? // Vergi dairesi
  company_legal_name  String? // Şirket adı (ticari unvan) — Firma adı (name) marka/görünen ad
  website             String?
  bank_iban_try       String? // opsiyonel — banka havalesi ödemelerinde alıcıya gösterilir
  bank_iban_usd       String?
  includes_vat        Boolean @default(false) // KDV dahil
  nationwide_shipping Boolean @default(false) // Tüm Türkiye nakliye
  same_day_shipping   Boolean @default(false) // Aynı gün sevkiyat (15:00'a kadar)

  // ==== Roaster (alıcı) kayıt alanları ====
  shipping_address       String? @db.Text // Sevk adresi (fatura adresinden farklıysa)
  ship_to_billing        Boolean @default(true) // "Fatura adresine gönderilsin mi?"
  shipping_contact_name  String? // ship_to_billing=false ise doldurulur
  shipping_contact_phone String?

  // ==== Zorunlu yasal onaylar (kayıt anında) ====
  kvkk_accepted_at            DateTime?
  security_policy_accepted_at DateTime?
  sales_agreement_accepted_at DateTime?

  members      OrganizationMember[]
  products     Product[]
  offers       Offer[]
  buyerOrders  Order[]              @relation("BuyerOrders")
  sellerOrders Order[]              @relation("SellerOrders")
  priceAlerts  PriceAlert[]
  favorites    ProductFavorite[]
}

model OrganizationMember {
  id              String @id @default(uuid())
  organization_id String
  user_id         String
  role_in_org     String // OWNER | MANAGER | STAFF

  organization Organization @relation(fields: [organization_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@unique([organization_id, user_id])
}

enum SystemRole {
  MEMBER
  ADMIN
}

enum OrgType {
  SELLER
  ROASTER // kavrulmus kahve ureticisi - alici tarafi (ciğ kahve satin alir, teklif verir)
}

enum MembershipTier {
  STANDARD
  BASIC
  PREMIUM
}

// ==== Konteyner Tipi (parametre tablosu) ====

// Kg/ton donusumu sabit (1 ton = 1000kg); konteyner kapasitesi urune/tasima
// seklime gore degistigi icin admin tarafindan yonetilen bir parametre tablosu.
model ContainerType {
  id            String   @id @default(uuid())
  name          String // orn. "20' Standart Konteyner"
  capacity_kg   Float // orn. 19200 (320 canta x 60kg)
  bag_count     Int?
  bag_weight_kg Float?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  products Product[]
}

// ==== Ürün (Çiğ Kahve) ====

model Product {
  id                String  @id @default(uuid())
  seller_org_id     String
  title             String
  country           String
  region            String?
  bean_type         String // Arabica | Robusta | Liberica | Excelsa | Blend
  harvest_year      Int?
  processing_method String? // Natural | Washed | Kurutulmuş
  moisture_pct      Float?
  description       String? @db.Text // ürün kartında gösterilen genel açıklama
  cupping_notes     String? @db.Text // tadım notları
  score             Float? // elle girilen kalite skoru
  greenbro_supplied Boolean @default(false) // bu parti GreenBro'ya tedarik ediliyor/uygun mu
  other_specs       Json?

  // Kanonik fiyat kg basinadir; ton ve konteyner fiyatlari ContainerType
  // kapasitesine gore otomatik hesaplanir, ancak satici toplu-alim iskontosu
  // icin bu ikisini elle override edebilir (null ise otomatik hesaplanir).
  price_per_kg        Decimal       @db.Decimal(12, 4)
  price_per_ton       Decimal?      @db.Decimal(12, 2)
  price_per_container Decimal?      @db.Decimal(14, 2)
  container_type_id   String?
  currency            String        @default("USD")
  quantity_kg         Float // stok tonaji kg cinsinden (orn. 19000 = 19 ton)
  is_featured         Boolean       @default(false)
  status              ProductStatus @default(ACTIVE) // ACTIVE | SOLD_OUT | ARCHIVED
  created_at          DateTime      @default(now())

  seller        Organization   @relation(fields: [seller_org_id], references: [id])
  containerType ContainerType? @relation(fields: [container_type_id], references: [id])
  offers        Offer[]
  priceAlerts   PriceAlert[]
  priceHistory  PriceHistory[]
  orders        Order[]
  favorites     ProductFavorite[]
}

// ==== Favori İlanlar ====

model ProductFavorite {
  id              String   @id @default(uuid())
  organization_id String
  product_id      String
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])
  product      Product      @relation(fields: [product_id], references: [id])

  @@unique([organization_id, product_id])
}

enum ProductStatus {
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

model PriceHistory {
  id          String   @id @default(uuid())
  product_id  String
  price       Decimal  @db.Decimal(12, 4) // kg basina fiyat
  recorded_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id])
}

// ==== Teklif Sistemi ====

model Offer {
  id           String      @id @default(uuid())
  offer_no     Int         @unique @default(autoincrement()) // insan-okunur teklif no (#123) — takip/referans icin
  product_id   String
  buyer_org_id String
  offer_price  Decimal     @db.Decimal(12, 4) // kg basina teklif fiyati
  quantity_kg  Float
  message      String?     @db.Text
  status       OfferStatus @default(PENDING) // PENDING | ACCEPTED | REJECTED | EXPIRED
  order_id     String?     @unique // ACCEPTED teklif siparise donusturulunce doldurulur
  created_at   DateTime    @default(now())

  product Product      @relation(fields: [product_id], references: [id])
  buyer   Organization @relation(fields: [buyer_org_id], references: [id])
  order   Order?       @relation(fields: [order_id], references: [id])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// ==== Fiyat Alarmı ====

model PriceAlert {
  id              String         @id @default(uuid())
  organization_id String
  product_id      String? // belirli ürün, veya null ise genel (ülke+tür bazlı)
  bean_type       String?
  country         String?
  target_price    Decimal        @db.Decimal(12, 4) // kg basina hedef fiyat
  direction       AlertDirection // BELOW | ABOVE
  channel_email   Boolean        @default(true)
  channel_sms     Boolean        @default(false)
  channel_push    Boolean        @default(true)
  is_active       Boolean        @default(true)
  triggered_at    DateTime?

  organization Organization @relation(fields: [organization_id], references: [id])
  product      Product?     @relation(fields: [product_id], references: [id])
}

enum AlertDirection {
  BELOW
  ABOVE
}

// ==== Satın Alma / Sipariş ====

model Order {
  id             String        @id @default(uuid())
  order_no       Int           @unique @default(autoincrement()) // insan-okunur siparis no (#45) — teklif no ile iliskilendirilir
  product_id     String
  buyer_org_id   String
  seller_org_id  String
  quantity_kg    Float
  unit_price     Decimal       @db.Decimal(12, 4) // kg basina fiyat
  total_amount   Decimal       @db.Decimal(14, 2)
  currency       String        @default("USD")
  payment_method PaymentMethod // CREDIT_CARD | BANK_TRANSFER
  payment_status PaymentStatus @default(PENDING)
  order_status   OrderStatus   @default(CREATED)
  created_at     DateTime      @default(now())

  product Product      @relation(fields: [product_id], references: [id])
  buyer   Organization @relation("BuyerOrders", fields: [buyer_org_id], references: [id])
  seller  Organization @relation("SellerOrders", fields: [seller_org_id], references: [id])
  offer   Offer?
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

// ==== Bildirim Log ====

model NotificationLog {
  id              String   @id @default(uuid())
  organization_id String
  channel         String // EMAIL | SMS | PUSH
  event_type      String // PRICE_ALERT | ORDER_CONFIRM | OFFER_UPDATE
  payload         Json?
  sent_at         DateTime @default(now())
}
