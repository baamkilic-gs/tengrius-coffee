# Supabase — Pooler (port 6543) uygulama bağlantıları için
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# Supabase — Direct (port 5432) yalnızca migration için
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

JWT_SECRET="dev-secret-change-me"

# Yayında Vercel adresiyle kısıtlanır — örn: "https://tengrius-coffee.vercel.app"
CORS_ORIGINS=

PORT=3001
